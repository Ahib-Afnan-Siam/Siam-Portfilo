# ─── Site ─────────────────────────────────────────────────────────────────────
# Canonical production URL used for SEO, sitemap, robots, and Open Graph.
# Local example:
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production example:
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Search Console verification token.
# Paste only the content="..." value from the Google verification meta tag.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ─── Contact form Gmail SMTP via Nodemailer ───────────────────────────────────
# SMTP_PASS is a Google App Password, not your normal Gmail password.
# Create it from your Google Account > Security > App passwords.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true

SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password

# Email address where contact form messages will be received.
CONTACT_EMAIL_TO=your-email@gmail.com

# ─── Admin panel (/admin) ─────────────────────────────────────────────────────
# Keep real credentials in .env.local only.
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=choose-a-strong-password

# Secret used to sign the admin session cookie.
# Generate one with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=generate-a-long-random-string